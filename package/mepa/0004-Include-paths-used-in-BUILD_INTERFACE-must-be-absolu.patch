           message(STATUS "Adding ${A_LIB} (${A_CHIP}) MESA=${has_mesa} Defines: [${DEFS}]")
           set_target_properties(${A_LIB} PROPERTIES EXCLUDE_FROM_ALL FALSE)
       else()
@@ -366,11 +369,14 @@ macro(API_TARGET)
