+  target_compile_options(${A_LIB}_static
+      PUBLIC ${DEFS}
+	  PRIVATE -Wno-format-security -Wno-sign-compare -Wno-type-limits -Wno-implicit-fallthrough -Wno-array-parameter -Wno-enum-conversion -Wno-logical-op
+  )
   
-  if (${A_LIB}_static)
