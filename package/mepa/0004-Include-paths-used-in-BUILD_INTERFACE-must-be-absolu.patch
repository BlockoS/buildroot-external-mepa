@@ -230,35 +233,35 @@ macro(MESA_CACHE)
     endif()
 endmacro(MESA_CACHE)
 
-FOREACH(f ${API_UNI_HDR})
+foreach(f ${API_UNI_HDR})
     # Add header to mesa processing
     MESA_CACHE("include/${f}")
-ENDFOREACH()
+endforeach()
 
-FOREACH(f ${API_MESA_HDR})
