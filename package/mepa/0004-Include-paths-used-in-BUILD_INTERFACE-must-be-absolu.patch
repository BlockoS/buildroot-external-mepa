     # Add all mepa headers
     configure_file("mepa/include/${f}" "${CMAKE_CURRENT_BINARY_DIR}/include_common/${f}" COPYONLY)
-ENDFOREACH()
+endforeach()
 
-FOREACH(f ${API_MEPA_VTSS_HDR})
